	"panels": [
		{
			"title": "Redis Match Engine Latency",
			"description": "Latência das operações EVALSHA do motor de matching no Redis",
			"type": "timeseries",
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "palette-classic" },
					"custom": {
						"axisBorderShow": false,
						"axisLabel": "latency",
						"drawStyle": "line",
						"fillOpacity": 15,
						"gradientMode": "scheme",
						"lineInterpolation": "smooth",
						"lineWidth": 2,
						"pointSize": 5,
						"showPoints": "auto",
						"spanNulls": false,
						"stacking": { "group": "A", "mode": "none" }
					},
					"unit": "s"
				},
				"overrides": []
			},
			"options": {
				"legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
				"tooltip": { "mode": "multi", "sort": "desc" }
			},
			"targets": [
				{
					"datasource": { "type": "prometheus", "uid": "prometheus" },
					"expr": "histogram_quantile(0.50, sum(rate(vibranium_redis_match_latency_seconds_bucket{job=\"order-service\"}[5m])) by (le))",
					"legendFormat": "p50",
					"refId": "A"
				},
				{
					"datasource": { "type": "prometheus", "uid": "prometheus" },
					"expr": "histogram_quantile(0.95, sum(rate(vibranium_redis_match_latency_seconds_bucket{job=\"order-service\"}[5m])) by (le))",
					"legendFormat": "p95",
					"refId": "B"
				},
				{
					"datasource": { "type": "prometheus", "uid": "prometheus" },
					"expr": "histogram_quantile(0.99, sum(rate(vibranium_redis_match_latency_seconds_bucket{job=\"order-service\"}[5m])) by (le))",
					"legendFormat": "p99",
					"refId": "C"
				}
			]
		},
