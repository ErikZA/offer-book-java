{
	"realm": "orderbook-realm",
	"enabled": true,

	"registrationAllowed": true,
	"registrationEmailAsUsername": false,
	"resetPasswordAllowed": true,
	"rememberMe": true,
	"verifyEmail": false,
	"loginWithEmailAllowed": true,
	"duplicateEmailsAllowed": false,

	"eventsListeners": ["jboss-logging", "keycloak-to-rabbitmq"],
	"eventsEnabled": true,
	"adminEventsEnabled": true,
	"adminEventsDetailsEnabled": true,
	"enabledEventTypes": [
		"REGISTER",
		"REGISTER_ERROR",
		"LOGIN",
		"LOGIN_ERROR",
		"LOGOUT",
		"UPDATE_PROFILE",
		"UPDATE_PASSWORD"
	],

	"roles": {
		"realm": [
			{ "name": "USER",  "description": "Papel básico de investidor" },
			{ "name": "ADMIN", "description": "Administrador do sistema"  }
		]
	},

	"defaultRoles": ["USER"],

	"clients": [
		{
			"clientId": "order-client",
			"enabled": true,
			"protocol": "openid-connect",
			"publicClient": true,
			"directAccessGrantsEnabled": true,
			"standardFlowEnabled": true,
			"redirectUris": [
				"http://localhost:8000/*",
				"http://localhost:8080/*",
				"http://localhost:3000/*"
			],
			"webOrigins": ["*"],
			"attributes": {
				"post.logout.redirect.uris": "+"
			}
		},
		{
			"clientId": "orderbook-ui",
			"enabled": true,
			"protocol": "openid-connect",
			"publicClient": true,
			"directAccessGrantsEnabled": true,
			"standardFlowEnabled": true,
			"redirectUris": [
				"http://localhost:8000/*",
				"http://localhost:3000/*",
				"*"
			],
			"webOrigins": ["*"]
		}
	],

	"users": [
		{
			"id": "00000000-0000-0000-0000-000000000001",
			"username": "tester",
			"enabled": true,
			"email": "tester@vibranium.com",
			"firstName": "Tester",
			"lastName": "Vibranium",
			"emailVerified": true,
			"credentials": [
				{
					"type": "password",
					"value": "test-password",
					"temporary": false
				}
			],
			"realmRoles": ["USER"]
		},
		{
			"id": "00000000-0000-0000-0000-000000000002",
			"username": "admin-user",
			"enabled": true,
			"email": "admin@vibranium.com",
			"firstName": "Admin",
			"lastName": "Vibranium",
			"emailVerified": true,
			"credentials": [
				{
					"type": "password",
					"value": "admin-password",
					"temporary": false
				}
			],
			"realmRoles": ["USER", "ADMIN"]
		}
	]
}
