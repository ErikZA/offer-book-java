# =============================================================================
# Vibranium Platform — variáveis de ambiente sensíveis
# =============================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores marcados com <CHANGE_ME>
#   3. NUNCA faça commit do .env (já está no .gitignore)
#
# Uso com Docker Compose (executar a partir da raiz do projeto):
#   docker compose -f infra/docker-compose.dev.yml --env-file .env up -d
#   docker compose -f infra/docker-compose.yml --env-file .env up -d
#   docker compose -f infra/docker-compose.staging.yml --env-file .env up -d
#
# Variáveis com valor padrão (:-) podem ser mantidas inalteradas em dev local.
# Variáveis sem padrão (:?) DEVEM ser definidas antes do compose subir.
#
# Variáveis marcadas [staging] são obrigatórias apenas em docker-compose.staging.yml.
# Variáveis marcadas [prod]    são obrigatórias em docker-compose.yml.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL — banco compartilhado (vibranium_orders + vibranium_wallet)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<CHANGE_ME>

# [staging] Senha do usuário de replicação `replicator` criado no primary.
# Usada por postgres-replica-1 e postgres-replica-2 no pg_basebackup e
# no primary_conninfo para streaming WAL. Deve ser idêntica nos 3 containers.
# Gerar com: openssl rand -hex 32
POSTGRES_REPLICATION_PASSWORD=<CHANGE_ME_generate_with_openssl_rand>

# -----------------------------------------------------------------------------
# RabbitMQ — message broker para eventos de domínio
# -----------------------------------------------------------------------------
RABBITMQ_DEFAULT_USER=vibranium
RABBITMQ_DEFAULT_PASS=<CHANGE_ME>

# [staging] Erlang cookie compartilhado pelo cluster de 3 nós.
# Gerar com: openssl rand -hex 32
RABBITMQ_ERLANG_COOKIE=<CHANGE_ME_generate_with_openssl_rand>

# -----------------------------------------------------------------------------
# MongoDB — event store do order-service
# -----------------------------------------------------------------------------
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=<CHANGE_ME>

# [staging] Chave compartilhada entre os 3 nós do replica set rs0.
# Deve ser idêntica nos 3 nós — mínimo 6 caracteres, base64 puro.
# Gerar com: openssl rand -base64 756 | tr -d '\n'
MONGO_REPLICA_KEY=<CHANGE_ME_generate_with_openssl_rand>

# -----------------------------------------------------------------------------
# Keycloak — Identity Provider (banco dedicado keycloak-db)
# -----------------------------------------------------------------------------
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=<CHANGE_ME>
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<CHANGE_ME>

# -----------------------------------------------------------------------------
# Kong — API Gateway
# [staging] Senha do banco Postgres dedicado ao Kong no cluster staging.
# -----------------------------------------------------------------------------
KONG_DB_PASSWORD=<CHANGE_ME>

# -----------------------------------------------------------------------------
# Redis — Autenticação (requirepass)
# Senhas DIFERENTES para Redis da aplicação e Redis do Kong (isolação).
# Gerar com: openssl rand -hex 32
# -----------------------------------------------------------------------------
# Redis da aplicação (order book, motor de match)
REDIS_PASSWORD=<CHANGE_ME>
# Redis dedicado ao Kong (rate-limiting distribuído)
REDIS_KONG_PASSWORD=<CHANGE_ME>
